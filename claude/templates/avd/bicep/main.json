            },
            "tags": {
              "type": "object",
              "defaultValue": {},
              "metadata": {
                "description": "Tags for the extension"
              }
            }
          },
          "variables": {
            "storageEndpointSuffix": "[environment().suffixes.storage]",
            "fslogixSharePath": "[format('\\\\{0}.file.{1}\\{2}', parameters('storageAccountName'), variables('storageEndpointSuffix'), parameters('fileShareName'))]",
            "delValue": "[if(parameters('deleteLocalProfile'), '1', '0')]",
            "tempValue": "[if(parameters('preventTempProfile'), '1', '0')]",
            "failValue": "[if(parameters('preventLoginOnFailure'), '1', '0')]",
            "scriptCommands": [
              "New-Item C:\\Temp -ItemType Directory -Force | Out-Null",
              "[Net.ServicePointManager]::SecurityProtocol=[Net.SecurityProtocolType]::Tls12",
              "Invoke-WebRequest -Uri https://aka.ms/fslogix_download -OutFile C:\\Temp\\FSLogix.zip -UseBasicParsing",
              "Expand-Archive C:\\Temp\\FSLogix.zip C:\\Temp\\FSLogix -Force",
              "Start-Process C:\\Temp\\FSLogix\\x64\\Release\\FSLogixAppsSetup.exe -ArgumentList /install,/quiet,/norestart -Wait",
              "Start-Sleep 10",
              "$p='HKLM:\\SOFTWARE\\FSLogix\\Profiles'",
              "New-Item $p -Force | Out-Null",
              "Set-ItemProperty $p Enabled 1 -Type DWord",
              "[format('Set-ItemProperty $p VHDLocations ''{0}'' -Type MultiString', variables('fslogixSharePath'))]",
              "[format('Set-ItemProperty $p SizeInMBs {0} -Type DWord', parameters('profileSizeMB'))]",
              "Set-ItemProperty $p IsDynamic 1 -Type DWord",
              "Set-ItemProperty $p VolumeType VHDX -Type String",
              "Set-ItemProperty $p FlipFlopProfileDirectoryName 1 -Type DWord",
              "[format('Set-ItemProperty $p DeleteLocalProfileWhenVHDShouldApply {0} -Type DWord', variables('delValue'))]",
              "[format('Set-ItemProperty $p PreventLoginWithTempProfile {0} -Type DWord', variables('tempValue'))]",
              "[format('Set-ItemProperty $p PreventLoginWithFailure {0} -Type DWord', variables('failValue'))]",
              "Set-ItemProperty $p LockedRetryCount 3 -Type DWord",
              "Set-ItemProperty $p LockedRetryInterval 15 -Type DWord",
              "Set-ItemProperty $p ProfileType 0 -Type DWord",
              "Set-ItemProperty $p ReAttachIntervalSeconds 15 -Type DWord",
              "Set-ItemProperty $p ReAttachRetryCount 3 -Type DWord",
              "Set-ItemProperty $p AccessNetworkAsComputerObject 0 -Type DWord"
            ],
            "officeCommands": "[if(parameters('enableOfficeContainer'), createArray('$o=''HKLM:\\SOFTWARE\\Policies\\FSLogix\\ODFC''', 'New-Item $o -Force | Out-Null', 'Set-ItemProperty $o Enabled 1 -Type DWord', format('Set-ItemProperty $o VHDLocations ''{0}'' -Type MultiString', variables('fslogixSharePath')), 'Set-ItemProperty $o SizeInMBs 30720 -Type DWord', 'Set-ItemProperty $o IsDynamic 1 -Type DWord', 'Set-ItemProperty $o VolumeType VHDX -Type String', 'Set-ItemProperty $o FlipFlopProfileDirectoryName 1 -Type DWord', 'Set-ItemProperty $o IncludeOfficeActivation 1 -Type DWord', 'Set-ItemProperty $o IncludeOneDrive 1 -Type DWord', 'Set-ItemProperty $o IncludeOutlook 1 -Type DWord', 'Set-ItemProperty $o IncludeTeams 1 -Type DWord'), createArray())]",
            "credCommands": "[if(parameters('useStorageKey'), createArray(format('cmdkey /add:{0}.file.{1} /user:Azure\\{2} /pass:{3}', parameters('storageAccountName'), variables('storageEndpointSuffix'), parameters('storageAccountName'), parameters('storageAccountKey'))), createArray())]",
            "cleanupCommands": [
              "Remove-Item C:\\Temp\\FSLogix* -Recurse -Force -ErrorAction SilentlyContinue"
            ],
            "allCommands": "[concat(variables('scriptCommands'), variables('officeCommands'), variables('credCommands'), variables('cleanupCommands'))]",
            "finalScript": "[join(variables('allCommands'), '; ')]"
          },
          "resources": [
            {
              "type": "Microsoft.Compute/virtualMachines/extensions",
              "apiVersion": "2023-03-01",
              "name": "[format('{0}/FSLogixConfig', parameters('vmName'))]",
              "location": "[parameters('location')]",
              "tags": "[parameters('tags')]",
              "properties": {
                "publisher": "Microsoft.Compute",
                "type": "CustomScriptExtension",
                "typeHandlerVersion": "1.10",
                "autoUpgradeMinorVersion": true,
                "protectedSettings": {
                  "commandToExecute": "[format('powershell -ExecutionPolicy Bypass -Command \"{0}\"', variables('finalScript'))]"
                }
              }
            }
          ],
          "outputs": {
            "provisioningState": {
              "type": "string",
              "metadata": {
                "description": "Extension provisioning state"
              },
              "value": "[reference(resourceId('Microsoft.Compute/virtualMachines/extensions', split(format('{0}/FSLogixConfig', parameters('vmName')), '/')[0], split(format('{0}/FSLogixConfig', parameters('vmName')), '/')[1]), '2023-03-01').provisioningState]"
            },
            "configuredVmName": {
              "type": "string",
              "metadata": {
                "description": "Configured VM name"
              },
              "value": "[parameters('vmName')]"
            }
          }
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Resources/deployments', 'deploy-file-share')]",
        "[resourceId('Microsoft.Resources/deployments', 'deploy-rbac-admins')]",
        "[resourceId('Microsoft.Resources/deployments', 'deploy-rbac-users')]",
        "[resourceId('Microsoft.Resources/deployments', 'deploy-storage-account')]"
      ]
    }
  ],
  "outputs": {
    "storageAccountName": {
      "type": "string",
      "metadata": {
        "description": "Storage account name"
      },
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'deploy-storage-account'), '2025-04-01').outputs.storageAccountName.value]"
    },
    "storageAccountId": {
      "type": "string",
      "metadata": {
        "description": "Storage account ID"
      },
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'deploy-storage-account'), '2025-04-01').outputs.storageAccountId.value]"
    },
    "fileShareUNC": {
      "type": "string",
      "metadata": {
        "description": "File share UNC path"
      },
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'deploy-file-share'), '2025-04-01').outputs.fileShareUNC.value]"
    },
    "configuredVMs": {
      "type": "array",
      "metadata": {
        "description": "Configured VMs"
      },
      "copy": {
        "count": "[length(parameters('vmNames'))]",
        "input": {
          "name": "[parameters('vmNames')[copyIndex()]]",
          "provisioningState": "[reference(resourceId('Microsoft.Resources/deployments', format('deploy-fslogix-{0}', parameters('vmNames')[copyIndex()])), '2025-04-01').outputs.provisioningState.value]"
        }
      }
    },
    "authenticationMethod": {
      "type": "string",
      "metadata": {
        "description": "Authentication method"
      },
      "value": "[if(parameters('enableAzureADKerberos'), 'Azure AD Kerberos', 'Storage Account Key')]"
    },
    "primaryFileEndpoint": {
      "type": "string",
      "metadata": {
        "description": "Primary file endpoint"
      },
      "value": "[reference(resourceId('Microsoft.Resources/deployments', 'deploy-storage-account'), '2025-04-01').outputs.primaryFileEndpoint.value]"
    }
  }
}